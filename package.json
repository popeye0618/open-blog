{
  "name": "blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "seed": "node --import tsx scripts/seed.ts && wrangler d1 execute blog --local --file=./drizzle/seed.sql",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply blog --local",
    "db:migrate:remote": "wrangler d1 migrations apply blog --remote",
    "hash-password": "node --import tsx scripts/hash-password.ts",
    "db:seed:local": "tsx scripts/seed.ts && wrangler d1 execute blog --local --file=./drizzle/seed.sql",
    "db:reset:local": "wrangler d1 execute blog --local --command=\"DROP TABLE IF EXISTS posts_fts; DROP TABLE IF EXISTS posts; DROP TABLE IF EXISTS comments; DROP TABLE IF EXISTS views; DROP TABLE IF EXISTS settings;\""
  },
  "dependencies": {
    "@astrojs/cloudflare": "11.2.0",
    "@astrojs/tailwind": "^6.0.2",
    "@resvg/resvg-wasm": "^2.6.2",
    "astro": "^4.16.19",
    "drizzle-orm": "^0.45.2",
    "isomorphic-dompurify": "^3.12.0",
    "jose": "^6.2.3",
    "marked": "^18.0.3",
    "nanoid": "^5.1.11",
    "satori": "^0.26.0",
    "shiki": "^4.0.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260505.1",
    "@tailwindcss/typography": "^0.5.19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "wrangler": "^4.87.0"
  }
}
