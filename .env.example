# 사이트 공개 URL. RSS/sitemap/OG에서 절대 경로로 사용. 끝에 슬래시 없이.
PUBLIC_SITE_URL=https://example.pages.dev

# 어드민 소유자 이메일. cf_access 정책 매칭에 사용.
OWNER_EMAIL=you@example.com

# 푸터/About 등에 표시되는 이름. settings 시드 시 owner_name 기본값.
OWNER_NAME=Your Name

# 어드민 인증 모드. cf_access | password
AUTH_MODE=cf_access

# AUTH_MODE=password일 때만 사용. scripts/hash-password.ts로 생성.
ADMIN_PASSWORD_HASH=

# AUTH_MODE=password일 때만 사용. 32바이트 이상 랜덤 문자열 (예: openssl rand -hex 32).
JWT_SECRET=

# Turnstile 공개 site key. 로컬 테스트 키는 README 참고.
PUBLIC_TURNSTILE_SITE_KEY=

# Turnstile secret key. 서버에서 토큰 검증에 사용.
TURNSTILE_SECRET=

# 댓글 IP 해시 솔트. 32바이트 랜덤. 한 번 정하면 바꾸지 말 것 (스팸 추적 연속성).
IP_HASH_SALT=
