---
import PostCard from '@/components/PostCard.astro';
import { getDb } from '@/db/client';
import RootLayout from '@/layouts/RootLayout.astro';
import { listPublishedPostsByTag } from '@/lib/posts';

const db = getDb(Astro.locals.runtime.env);
const tag = decodeURIComponent(Astro.params.tag ?? '');
const posts = await listPublishedPostsByTag(db, tag);
---

<RootLayout title={`#${tag} 태그`} description={`${tag} 태그로 작성된 글 목록입니다.`}>
  <section class="not-prose mb-10">
    <p class="mb-3 text-sm font-semibold text-ink/55">Tag</p>
    <h1 class="font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">
      #{tag}
    </h1>
  </section>

  {posts.length > 0 ? (
    <section class="not-prose grid gap-5 md:grid-cols-2" aria-label={`${tag} 태그 글 목록`}>
      {posts.map((post) => <PostCard post={post} />)}
    </section>
  ) : (
    <p class="not-prose rounded-lg border border-ink/10 bg-white/45 p-6 text-center text-ink/65 shadow-soft">
      이 태그로 작성된 글이 없습니다.
    </p>
  )}
</RootLayout>
