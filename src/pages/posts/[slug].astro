---
import CommentForm from '@/components/CommentForm.astro';
import CommentList from '@/components/CommentList.astro';
import Toc from '@/components/Toc.astro';
import ViewCounter from '@/components/ViewCounter.astro';
import { getDb } from '@/db/client';
import RootLayout from '@/layouts/RootLayout.astro';
import { listVisibleComments } from '@/lib/comments';
import { getAdjacentPosts, getPostBySlug } from '@/lib/posts';
import { extractToc, renderMarkdown } from '@/lib/markdown';
import { getViewCount } from '@/lib/views';

const slug = Astro.params.slug ?? '';
const db = getDb(Astro.locals.runtime.env);
const post = await getPostBySlug(db, slug);
const initialViewCount = post ? await getViewCount(db, post.slug) : 0;

if (!post) {
  Astro.response.status = 404;
}

const html = post ? await renderMarkdown(post.bodyMd) : '';
const toc = post ? extractToc(post.bodyMd) : [];
const adjacent = post ? await getAdjacentPosts(db, post) : { prev: null, next: null };
const comments = post ? await listVisibleComments(db, post.id) : [];
const turnstileSiteKey = Astro.locals.runtime.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
const tags = post ? parseTags(post.tags) : [];
const date = post?.publishedAt ? formatDate(post.publishedAt) : '';
const lang = post?.lang === 'en' ? 'en' : 'ko';

function formatDate(value: string): string {
  return value.slice(0, 10).replaceAll('-', '.');
}

function parseTags(value: string): string[] {
  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed.filter((tag) => typeof tag === 'string') : [];
  } catch {
    return [];
  }
}
---

{post ? (
  <RootLayout title={post.title} description={post.description ?? undefined} lang={lang} ogImageSlug={post.slug} wide>
    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_14rem] lg:gap-10">
      <article class="prose prose-pastel min-w-0 max-w-none">
        <header class="not-prose mb-8">
          <h1 class="font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">{post.title}</h1>
          <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-ink/60">
            {date && <time datetime={post.publishedAt ?? undefined}>{date}</time>}
            <span class="rounded-full bg-mint/60 px-2.5 py-1 text-xs font-semibold text-ink/70">{post.lang}</span>
            <ViewCounter slug={post.slug} initialCount={initialViewCount} />
            {post.series && <span class="rounded-full bg-lavender/45 px-2.5 py-1 text-xs font-semibold text-ink/70">시리즈 · {post.series}</span>}
            {tags.map((tag) => (
              <a class="rounded-full bg-butter/70 px-2.5 py-1 text-xs font-semibold text-ink/70 no-underline transition hover:bg-peach/70" href={`/tags/${tag}`}>
                #{tag}
              </a>
            ))}
          </div>
        </header>

        {post.coverImage && (
          <img
            class="not-prose mb-8 aspect-[16/9] w-full rounded-lg border border-ink/10 object-cover shadow-soft"
            src={post.coverImage}
            alt=""
          />
        )}

        <hr />
        <div class="mt-8" set:html={html} />

        <CommentList comments={comments} />
        <CommentForm postId={post.id} siteKey={turnstileSiteKey} />

        <nav class="not-prose mt-12 grid gap-4 border-t border-ink/10 pt-6 sm:grid-cols-2" aria-label="Post navigation">
          {adjacent.prev ? (
            <a class="rounded-lg border border-ink/10 bg-white/45 p-4 text-sm text-ink/65 shadow-soft transition hover:bg-white/70" href={`/posts/${adjacent.prev.slug}`}>
              <span class="block text-xs font-semibold uppercase tracking-wide text-ink/45">Prev</span>
              <span class="mt-1 block font-display text-lg font-bold text-ink">{adjacent.prev.title}</span>
            </a>
          ) : <span />}
          {adjacent.next ? (
            <a class="rounded-lg border border-ink/10 bg-white/45 p-4 text-right text-sm text-ink/65 shadow-soft transition hover:bg-white/70" href={`/posts/${adjacent.next.slug}`}>
              <span class="block text-xs font-semibold uppercase tracking-wide text-ink/45">Next</span>
              <span class="mt-1 block font-display text-lg font-bold text-ink">{adjacent.next.title}</span>
            </a>
          ) : <span />}
        </nav>
      </article>

      <aside>
        <Toc items={toc} />
      </aside>
    </div>
  </RootLayout>
) : (
  <RootLayout title="찾을 수 없는 페이지입니다">
    <section class="not-prose rounded-lg border border-ink/10 bg-white/45 p-8 text-center shadow-soft">
      <h1 class="font-display text-3xl font-bold text-ink">찾을 수 없는 페이지입니다</h1>
      <a class="mt-5 inline-block font-semibold text-ink underline decoration-peach decoration-2 underline-offset-4" href="/">홈으로 돌아가기</a>
    </section>
  </RootLayout>
)}
