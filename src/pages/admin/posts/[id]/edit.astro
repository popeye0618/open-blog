---
import { eq } from 'drizzle-orm';

import AdminLayout from '@/components/admin/AdminLayout.astro';
import PostEditor from '@/components/admin/PostEditor.astro';
import { getDb, schema } from '@/db/client';

const id = Number(Astro.params.id);
const db = getDb(Astro.locals.runtime.env);
const post = Number.isInteger(id) && id > 0
  ? await db.select().from(schema.posts).where(eq(schema.posts.id, id)).limit(1).get()
  : null;

if (!post) {
  Astro.response.status = 404;
}
---

<AdminLayout title={post ? `글 편집 · ${post.title}` : '글을 찾을 수 없음'}>
  {post ? (
    <>
      <header class="mb-6">
        <p class="text-sm font-semibold text-ink/55">글 편집</p>
        <h1 class="font-display text-4xl font-bold">{post.title}</h1>
      </header>

      <PostEditor mode="edit" initial={post} />
    </>
  ) : (
    <section class="rounded-lg border border-ink/10 bg-white/45 p-8 text-center shadow-soft">
      <h1 class="font-display text-3xl font-bold">글을 찾을 수 없습니다.</h1>
      <a class="mt-5 inline-block font-semibold text-ink underline decoration-peach decoration-2 underline-offset-4" href="/admin/posts">
        목록으로 돌아가기
      </a>
    </section>
  )}
</AdminLayout>
