---
interface Props {
  items: { id: string; text: string; depth: 2 | 3 }[];
}

const { items } = Astro.props;
---

<nav class="not-prose sticky top-8 hidden rounded-lg border border-ink/10 bg-white/45 p-4 text-sm shadow-soft lg:block" aria-label="Table of contents">
  <p class="mb-3 font-display text-base font-bold text-ink">Contents</p>
  <ol class="space-y-2">
    {items.map((item) => (
      <li class={item.depth === 3 ? 'pl-4' : ''}>
        <a class="text-ink/65 transition hover:text-ink" href={`#${item.id}`}>{item.text}</a>
      </li>
    ))}
  </ol>
</nav>
