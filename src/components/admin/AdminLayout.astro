---
import '../../styles/global.css';

interface Props {
  title: string;
  wide?: boolean;
}

const { title, wide = false } = Astro.props;
const session = Astro.locals.session;
const authMode = Astro.locals.runtime.env.AUTH_MODE ?? 'cf_access';
const pageTitle = `${title} · Admin`;
const containerClass = `mx-auto px-4 py-8 lg:px-8 lg:py-10 ${wide ? 'max-w-7xl' : 'max-w-5xl'}`;
const navItems = [
  { href: '/admin', label: '대시보드' },
  { href: '/admin/posts', label: '글' },
  { href: '/admin/comments', label: '댓글' },
  { href: '/admin/settings', label: '설정' },
  { href: '/admin/views', label: '조회수' },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="min-h-screen bg-cream text-ink">
      <aside class="border-b border-ink/10 bg-white/50 lg:fixed lg:inset-y-0 lg:left-0 lg:w-64 lg:border-b-0 lg:border-r">
        <div class="mx-auto flex max-w-5xl flex-wrap items-center gap-4 px-4 py-4 lg:h-full lg:flex-col lg:items-stretch lg:px-6 lg:py-8">
          <a class="font-display text-2xl font-bold text-ink no-underline" href="/admin">Admin</a>
          <nav class="flex flex-wrap gap-2 text-sm font-semibold lg:flex-col" aria-label="Admin navigation">
            {navItems.map((item) => (
              <a class="rounded-full px-3 py-2 text-ink/70 transition hover:bg-peach/35 hover:text-ink lg:rounded-lg" href={item.href}>
                {item.label}
              </a>
            ))}
          </nav>
          <div class="ml-auto flex items-center gap-3 text-xs text-ink/55 lg:mt-auto lg:ml-0 lg:flex-col lg:items-start">
            {session?.email && <span>{session.email}</span>}
            {authMode === 'password' && (
              <form method="post" action="/api/auth/logout">
                <button class="rounded-full border border-ink/10 bg-white/60 px-3 py-1.5 font-semibold text-ink/65 transition hover:bg-peach/35" type="submit">
                  로그아웃
                </button>
              </form>
            )}
          </div>
        </div>
      </aside>

      <main class="lg:pl-64">
        <div class={containerClass}>
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
