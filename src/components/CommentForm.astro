---
interface Props {
  postId: number;
  siteKey: string;
  parentId?: number;
}

const { postId, siteKey, parentId } = Astro.props;
---

<section class="not-prose mt-8 rounded-lg border border-ink/10 bg-white/50 p-5 shadow-soft">
  <h2 class="font-display text-2xl font-bold text-ink">댓글 쓰기</h2>

  {siteKey ? (
    <form class="mt-5 space-y-4" action="/api/comments" method="post">
      <input type="hidden" name="post_id" value={postId} />
      {parentId && <input type="hidden" name="parent_id" value={parentId} />}

      <div>
        <label class="mb-2 block text-sm font-semibold text-ink/70" for="comment-author">
          이름
        </label>
        <input
          id="comment-author"
          class="w-full rounded-lg border border-ink/10 bg-cream/70 px-4 py-3 text-sm text-ink outline-none transition focus:border-peach focus:ring-2 focus:ring-peach/50"
          type="text"
          name="author_name"
          maxlength="40"
          required
        />
      </div>

      <div>
        <label class="mb-2 block text-sm font-semibold text-ink/70" for="comment-body">
          댓글
        </label>
        <textarea
          id="comment-body"
          class="min-h-32 w-full resize-y rounded-lg border border-ink/10 bg-cream/70 px-4 py-3 text-sm leading-6 text-ink outline-none transition focus:border-peach focus:ring-2 focus:ring-peach/50"
          name="body_md"
          maxlength="2000"
          required
        ></textarea>
      </div>

      <script is:inline>
        window.onCommentTurnstileError = function () {
          return true;
        };
      </script>
      <div
        class="cf-turnstile"
        data-sitekey={siteKey}
        data-theme="light"
        data-error-callback="onCommentTurnstileError"
      ></div>
      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

      <button
        class="inline-flex rounded-full bg-ink px-5 py-2.5 text-sm font-semibold text-cream shadow-soft transition hover:bg-ink/85 focus:outline-none focus:ring-2 focus:ring-peach/60"
        type="submit"
      >
        댓글 등록
      </button>
    </form>
  ) : (
    <p class="mt-4 rounded-lg border border-pink/40 bg-pink/20 p-4 text-sm text-ink/70">
      Turnstile 사이트 키가 설정되지 않아 댓글을 작성할 수 없습니다.
    </p>
  )}
</section>
